<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <View
        android:id="@+id/view_split"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/mcv_user"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        app:cardCornerRadius="16dp"
        app:layout_constraintTop_toBottomOf="@id/view_split">

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tv_username"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:textAppearance="?attr/textAppearanceTitleLargeEmphasized"
            tools:text="guest" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tv_server"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="48dp"
            android:textAppearance="?attr/textAppearanceLabelMedium"
            tools:text="192.168.50.5" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/mb_test_connection"
            style="?attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="64dp"
            android:layout_marginEnd="16dp"
            android:text="@string/setting_test_connection" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/siv_avatar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="end"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="16dp"
            app:cornerSize="24dp" />

    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/mcv_cache"
        android:layout_width="match_parent"
        android:layout_height="192dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/mcv_user">

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            android:text="@string/setting_offline_storage"
            android:textAppearance="?attr/textAppearanceTitleLargeEmphasized" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tv_storage_usage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:layout_marginStart="24dp"
            android:layout_marginTop="58dp"
            android:text="@string/setting_storage_usage"
            android:textAppearance="?attr/textAppearanceLabelMedium" />

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_marginTop="34dp"
            android:layout_marginEnd="24dp"
            android:text="@string/setting_storage_limit"
            android:textAppearance="?attr/textAppearanceTitleMediumEmphasized" />

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/lpi_used"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="96dp"
            android:indeterminate="false"
            app:trackCornerRadius="4dp"
            app:trackThickness="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/mb_clear_cache"
            style="?attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="16dp"
            android:text="@string/setting_clear_cache" />

    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/mcv_donate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        app:contentPadding="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/mcv_cache">

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/setting_donate"
            android:textAppearance="?attr/textAppearanceTitleMediumEmphasized" />

        <androidx.appcompat.widget.AppCompatImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="36dp"
            app:srcCompat="@drawable/donate" />

    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/mb_login"
        android:layout_width="match_parent"
        android:layout_height="66dp"
        android:layout_marginHorizontal="24dp"
        android:text="@string/setting_login"
        app:layout_constraintBottom_toTopOf="@id/ll_info" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/mb_logout"
        android:layout_width="match_parent"
        android:layout_height="66dp"
        android:layout_marginHorizontal="24dp"
        android:text="@string/setting_logout"
        app:layout_constraintBottom_toTopOf="@id/ll_info" />

    <androidx.appcompat.widget.LinearLayoutCompat
        android:id="@+id/ll_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/setting_author"
            android:textAppearance="?attr/textAppearanceLabelMedium" />

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/setting_blog"
            android:textAppearance="?attr/textAppearanceLabelMedium" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tv_version"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/setting_version"
            android:textAppearance="?attr/textAppearanceLabelMedium" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tv_issue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/setting_issue"
            android:textAppearance="?attr/textAppearanceLabelMedium"
            android:textColor="@color/setting_info_url" />

    </androidx.appcompat.widget.LinearLayoutCompat>

</androidx.constraintlayout.widget.ConstraintLayout>