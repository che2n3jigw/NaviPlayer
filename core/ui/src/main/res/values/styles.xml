<resources>

    <style name="Widget.NaviPlayer.Top.IconButton" parent="Widget.AppCompat.ImageButton">
        <item name="android:minWidth">48dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:background">?attr/actionBarItemBackground</item>
    </style>


    <!--图标按钮样式-->
    <style name="Widget.NaviPlayer.IconButton" parent="Widget.AppCompat.ImageButton">
        <item name="android:layout_width">40dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:background">?attr/selectableItemBackgroundBorderless</item>
        <item name="android:padding">8dp</item>
    </style>

    <!--顶部标题样式-->
    <style name="Widget.NaviPlayer.Top.Title" parent="Widget.MaterialComponents.TextView">
        <item name="android:textColor">?attr/colorOnPrimary</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:layout_marginTop">16dp</item>
    </style>

    <!--顶部操作按钮样式-->
    <style name="Widget.NaviPlayer.Top.Action" parent="Widget.MaterialComponents.TextView">
        <item name="android:layout_width">40dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:layout_marginEnd">8dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">?attr/colorOnPrimary</item>
        <item name="android:textSize">16sp</item>
    </style>

    <!--文本按钮样式-->
    <style name="Widget.NaviPlayer.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">?attr/colorOnPrimary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">16dp</item>
    </style>

    <!--内容标题样式-->
    <style name="TextAppearance.NaviPlayer.Content.Title" parent="TextAppearance.AppCompat">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">16sp</item>
    </style>

    <!--内容二级标题样式-->
    <style name="TextAppearance.NaviPlayer.Content.SubTitle" parent="TextAppearance.AppCompat">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
    </style>

</resources>